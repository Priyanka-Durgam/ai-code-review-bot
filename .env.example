# Groq — free & fast LLM API. Get a key at https://console.groq.com
GROQ_API_KEY=

# GitHub personal access token with 'repo' scope.
# Create at https://github.com/settings/tokens (classic token is simplest)
GITHUB_TOKEN=

# A secret string YOU make up. Must match the secret you set on the
# GitHub webhook (Settings > Webhooks > Secret).
GITHUB_WEBHOOK_SECRET=
